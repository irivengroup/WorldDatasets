{
  "name": "iriven/php-countries-data",
  "description": "Enterprise-ready countries dataset service backed by SQLite",
  "type": "library",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "Iriven\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-sqlite3": "*",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12"
  },
  "suggest": {
    "monolog/monolog": "For production logging integration"
  },
  "scripts": {
    "import-data": "php bin/import_countries.php",
    "validate-data": "php bin/validate_countries.php",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "countries": "php bin/countries",
    "import": "php bin/import_countries.php"
  }
}