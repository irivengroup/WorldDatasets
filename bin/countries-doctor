#!/usr/bin/env php
<?php

declare(strict_types=1);

use Iriven\WorldDatasets\Application\Factory\WorldDatasetsFactory;

require_once __DIR__ . '/../vendor/autoload.php';

$issues = [];

foreach ([
    WorldDatasetsFactory::defaultSqlitePath(),
    WorldDatasetsFactory::defaultJsonPath(),
    WorldDatasetsFactory::defaultCsvPath(),
] as $path) {
    if (!is_file($path)) {
        $issues[] = 'Missing file: ' . $path;
    }
}

try {
    $service = WorldDatasetsFactory::make();
    $service->country('FR');
    $service->country('US');
    $service->country('JP');
} catch (Throwable $e) {
    $issues[] = 'Resolution check failed: ' . $e->getMessage();
}

if ($issues === []) {
    echo "OK" . PHP_EOL;
    exit(0);
}

foreach ($issues as $issue) {
    echo $issue . PHP_EOL;
}
exit(1);
